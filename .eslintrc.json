{
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "env": {
    "es2021": true,
    "react-native/react-native": true,
    "browser": true
  },
  "globals": {
    "__dirname": "readonly",
    "require": "readonly",
    "module": "readonly",
    "process": "readonly",
    "console": "readonly",
    "Promise": "readonly",
    "setTimeout": "readonly",
    "clearTimeout": "readonly",
    "alert": "readonly",
    "fetch": "readonly",
    "FormData": "readonly",
    "URL": "readonly"
  },
  "rules": {
    "no-undef": "error"
  }
}
